# ── Groq (Analyse API) ───────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Database (shared by analyse & rebutt) ─────────────────────────────────────
# Auto-resolved to redpill-radar/data/redpill_radar.db unless overridden:
# DATABASE_URL=sqlite+aiosqlite:///absolute/path/to/db

# ── Twitter/X (Collect module) ───────────────────────────────────────────────
TWITTER_USERNAME=your-twitter-username
TWITTER_EMAIL=your-email@example.com
TWITTER_PASSWORD=your-password

# ── Analyse API (Collect & Dashboard call this) ─────────────────────────────
ANALYSE_API_URL=http://localhost:8000
# ANALYSE_API_KEY=optional-bearer-token
